{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anotaí!",
  "version": "0.1.1",
  "identifier": "com.christophergouveia.anotai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Anotaí!",
        "width": 1100,
        "height": 760,
        "minWidth": 640,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Anotações em pós-it, simples e bonitas.",
    "longDescription": "Anotaí! é um app minimalista de anotações com visual de pós-it, feito pra você nunca mais esquecer do que importa."
  }
}
